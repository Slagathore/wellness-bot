# =============================================================================
# WELLNESS BOT — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED — bot will not start without these
# -----------------------------------------------------------------------------

# Telegram bot token — get one from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Roleplay/Adventure Mini App (Telegram WebApp). Optional. When enabled, a
# "Play in App" button appears on the /adventure hub. WEBAPP_URL must be a
# public HTTPS URL that serves app.interfaces.webapp.server (behind TLS) - use a
# Cloudflare tunnel (cloudflared.yml) or another TLS proxy; 127.0.0.1 will not
# work as a Telegram WebApp button. start_all.ps1 launches the server + tunnel
# when WEBAPP_ENABLED=true.
# Run it manually with:  python -m app.interfaces.webapp.server
WEBAPP_ENABLED=false
WEBAPP_URL=
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8130
# Optional password to open the webapp in a normal browser (outside Telegram),
# mapped to the ADMIN_USERNAME account. Leave empty to keep it Telegram-only.
# (Telegram itself never needs it - the /webapp command / "Open on Web" button
# hands out short-lived per-user login links instead.)
WEBAPP_ACCESS_TOKEN=

# Admin Telegram username (no @ prefix) — grants access to the admin web GUI
ADMIN_USERNAME=your_telegram_username

# Admin web GUI password (plain text; hashed on first login)
ADMIN_PASSWORD=change_me_before_running

# Long-lived trust cookie for the admin session (any long random string)
ADMIN_TRUST_TOKEN=change_me_to_a_long_random_string

# -----------------------------------------------------------------------------
# DATA PATHS
# Use forward slashes even on Windows, or absolute paths for your OS.
# The bot will create these directories on first run if they don't exist.
# -----------------------------------------------------------------------------

DATA_ROOT=./wellness_data
DATABASE_PATH=./wellness_data/telegram_wellness.db

# -----------------------------------------------------------------------------
# INFRASTRUCTURE (local defaults work for dev)
# -----------------------------------------------------------------------------

# Redis — used as the internal event bus
REDIS_URL=redis://localhost:6379/0

# Ollama — local LLM inference server
OLLAMA_HOST=http://localhost:11434

# -----------------------------------------------------------------------------
# AI MODELS
# The bot supports local Ollama models and cloud models. Requests always go to
# your local Ollama at OLLAMA_HOST; for a model tagged ":cloud" (e.g.
# kimi-k2.7-code:cloud), Ollama itself forwards that request to its hosted
# service. A plain local model tag never leaves OLLAMA_HOST.
#
# Heads up: VISION_MODEL, PLANNER_MODEL, and NIGHTLY_MODEL default to a CLOUD
# model in code (app/config.py) if left unset here. PLANNER_MODEL also drives
# the always on sentiment worker, which scores every message you send.
# NIGHTLY_MODEL drives the nightly job that sends a user's recent messages
# off to build a psychological profile. See the README section "Model
# defaults and what leaves your machine" and SECURITY.md before you assume
# this setup is all local.
# -----------------------------------------------------------------------------

# Main conversation model. Local by default.
CHAT_MODEL=llama3:latest

# Background worker model: reminder text, embedding prompt fixes. Falls back
# to CHAT_MODEL (local) if unset. Does NOT cover sentiment scoring or nightly
# profiling below, those use PLANNER_MODEL / NIGHTLY_MODEL regardless of this
# setting.
WORKER_MODEL=

# Vision model, used for image analysis and OCR when you send the bot a
# photo. Set here so this stays local; leaving it blank falls back to a cloud
# model (mistral-large-3:675b-cloud) in code.
VISION_MODEL=llava:latest

# Turn planner (off by default, behind a feature flag) and the always on
# sentiment worker, which scores every user message within seconds of it
# being sent. Leaving this blank uses the code default, a CLOUD model
# (mistral-large-3:675b-cloud). Uncomment and set a local model to keep
# sentiment scoring on your machine:
# PLANNER_MODEL=llama3:latest

# Nightly psychological profiling job (app/workers/nightly.py). Once a user
# has sent 20+ messages, this sends up to 50 of their most recent messages to
# this model every night and stores the resulting profile. Leaving this blank
# uses the code default, a CLOUD model (kimi-k2.7-code:cloud). Uncomment and
# set a local model to keep this job on your machine:
# NIGHTLY_MODEL=llama3:latest

# Embedding model, used for semantic memory and RAG
EMBED_MODEL=nomic-embed-text

# Thinking (reasoning) control for thinking-capable models (e.g. kimi-k2.7-code).
# LLM_THINK: false | true | low | medium | high
# SHOW_THINKING exposes the model's reasoning in responses; keep false to hide it.
LLM_THINK=false
SHOW_THINKING=false

# -----------------------------------------------------------------------------
# VECTOR BACKEND
# 'numpy'      — pure Python, works everywhere, no native deps
# 'sqlite-vec' — fast, requires native sqlite-vec extension (may have issues on Windows)
# 'sqlite-vss' — fallback if sqlite-vec fails
# -----------------------------------------------------------------------------

VECTOR_BACKEND=numpy

# -----------------------------------------------------------------------------
# CONTEXT / RETRIEVAL
# -----------------------------------------------------------------------------

CTX_TOKEN_BUDGET=120000
TOP_K_RETRIEVAL=5

# -----------------------------------------------------------------------------
# FEATURE FLAGS (JSON object — set false to disable a feature)
# -----------------------------------------------------------------------------

APP_FEATURE_FLAGS={"user_feedback": true, "token_budget_dynamic": true, "nsfw_preferences": true, "adaptive_psych_tests": true, "profile_personalization_agent": true, "enhanced_text_cleaning": true, "multi_document_import": true, "conversation_memory_v2": true, "discord_bot": false}

# -----------------------------------------------------------------------------
# DISCORD INTEGRATION (optional — set discord_bot: true in APP_FEATURE_FLAGS)
# Get credentials from https://discord.com/developers/applications
# -----------------------------------------------------------------------------

DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# ADMIN DANGEROUS TOOLS (keep false in production)
# These unlock admin-panel features that can modify the database directly.
# -----------------------------------------------------------------------------

ENABLE_DANGEROUS_TOOLS=false
ADMIN_LLM_CONSOLE_ENABLED=false
ADMIN_DB_EDIT_ENABLED=false
ADMIN_OMNI_BROADCAST_ENABLED=false

# -----------------------------------------------------------------------------
# IMAGE GENERATION (optional)
# All image generation is delegated to the standalone DungeonMaster SDXL server
# (run `python dm_imagegen.py --serve` in the DungeonMaster repo). The bot POSTs
# a prompt and gets a PNG back — no torch/diffusers in this process. If the
# server is down, image buttons hide and /imagine reports it gracefully.
# -----------------------------------------------------------------------------

DM_IMAGE_URL=http://127.0.0.1:8500
DM_IMAGE_ENABLED=true
DM_IMAGE_TIMEOUT_SECONDS=300

# HuggingFace token (optional — for gated models)
HF_TOKEN=
