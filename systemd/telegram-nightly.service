[Unit]
Description=Telegram Wellness Bot - Nightly Jobs
After=network.target

[Service]
Type=simple
User=telegram-bot
WorkingDirectory=/opt/telegram_wellness_bot
Environment="PATH=/opt/telegram_wellness_bot/venv/bin"
ExecStart=/opt/telegram_wellness_bot/venv/bin/python -m app.workers.nightly
Restart=always
RestartSec=60

[Install]
WantedBy=multi-user.target
